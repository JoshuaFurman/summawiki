{
  "manifest_version": 3,
  "name": "SummaWiki",
  "version": "1.1",
  "description": "Displays a preview of Wikipedia pages when you hover over their links.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "exclude_matches": ["*://*.wikipedia.org/*"]
    }
  ],
  "host_permissions": [
    "*://*.wikipedia.org/*"
  ]
}
